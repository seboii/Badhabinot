  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Backend Durumu",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "KAPALI", "color": "red" }, "1": { "text": "ÇALIŞIYOR", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"badhabinot-backend\"}" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Çalışma Süresi",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_uptime_seconds{application=\"badhabinot-backend\"}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM Heap Kullanımı",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_used_bytes{application=\"badhabinot-backend\", area=\"heap\"})", "legendFormat": "heap used" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_committed_bytes{application=\"badhabinot-backend\", area=\"heap\"})", "legendFormat": "heap committed" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP İstek Hızı (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{application=\"badhabinot-backend\"}[1m]))", "legendFormat": "toplam" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Kullanımı",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_cpu_usage{application=\"badhabinot-backend\"}", "legendFormat": "process" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_cpu_usage{application=\"badhabinot-backend\"}", "legendFormat": "system" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Yanıt Süresi (p95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"badhabinot-backend\"}[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ],
