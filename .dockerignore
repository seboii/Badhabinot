# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node / frontend ───────────────────────────────────────────────────────────
frontend/node_modules
frontend/.vite
frontend/dist

# ── Python bytecode & caches ──────────────────────────────────────────────────
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.coverage
coverage

# ── Python virtual environments ───────────────────────────────────────────────
**/.venv
**/venv
**/env

# ── Java / Maven build outputs ────────────────────────────────────────────────
**/target
.idea
.vscode

# ── Logs & runtime data ───────────────────────────────────────────────────────
tmp
*.log
python-services/vision-service/logs
python-services/vision-service/data/users

# ── ML model caches (downloaded at first inference, not baked into the image) ──
**/.cache
**/.ultralytics
**/.deepface

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
