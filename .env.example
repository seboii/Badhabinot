# Database
POSTGRES_USER=badhabinot
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
REDIS_PORT=6379

# Internal auth
SECURITY_JWT_SECRET=
INTERNAL_API_KEY=

# Published ports
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
MONITORING_SERVICE_PORT=8083
VISION_SERVICE_PORT=8091
AI_SERVICE_PORT=8092
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# Internal service URLs
AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8082
MONITORING_SERVICE_URL=http://monitoring-service:8083
VISION_SERVICE_URL=http://vision-service:8091
AI_SERVICE_URL=http://ai-service:8092

# AI adapter
AI_PROVIDER=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL_NAME=gpt-4.1-mini
AI_TIMEOUT_SECONDS=30
AI_READINESS_TIMEOUT_SECONDS=10
AI_MAX_RETRIES=2
AI_TEMPERATURE=0.1

# Shared runtime settings
VISION_SERVICE_READ_TIMEOUT=PT10S
AI_SERVICE_READ_TIMEOUT=PT25S
LOG_LEVEL=INFO
USER_CONTEXT_CACHE_TTL=PT5M
ANALYSIS_JOB_CACHE_TTL=PT15M
ANALYSIS_JOB_KEY_PREFIX=badhabinot:monitoring:analysis-job:

# Frontend local development
VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Optional JVM flags
GATEWAY_JAVA_OPTS=
AUTH_SERVICE_JAVA_OPTS=
USER_SERVICE_JAVA_OPTS=
MONITORING_SERVICE_JAVA_OPTS=
