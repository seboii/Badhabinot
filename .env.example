# Database
POSTGRES_USER=badhabinot
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
REDIS_PORT=6379

# Internal auth
SECURITY_JWT_SECRET=
INTERNAL_API_KEY=

# Published ports
BACKEND_PORT=8080
VISION_SERVICE_PORT=8091
AI_SERVICE_PORT=8092
FRONTEND_PORT=3000
OLLAMA_PORT=11434

# Internal service URLs
AUTH_SERVICE_URL=http://backend:8080
USER_SERVICE_URL=http://backend:8080
MONITORING_SERVICE_URL=http://backend:8080
VISION_SERVICE_URL=http://vision-service:8091
AI_SERVICE_URL=http://ai-service:8092

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# AI_PROVIDER options:
#   "ollama"            — local Ollama container in Docker network (default)
#   "openai-compatible" — any OpenAI-compatible API (requires AI_API_KEY)
#   "mock"              — deterministic offline mode for testing
#
# Default is "ollama" — model is auto-pulled on first start via ollama-pull service.
# Switch to "openai-compatible" and fill AI_API_KEY to use a cloud LLM instead.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_NAME=badhabinot:latest
OLLAMA_BASE_MODEL_NAME=qwen2.5:7b

# OpenAI-compatible settings (only needed when AI_PROVIDER=openai-compatible)
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL_NAME=gpt-4.1-mini

AI_TIMEOUT_SECONDS=60
AI_READINESS_TIMEOUT_SECONDS=10
AI_MAX_RETRIES=2
AI_TEMPERATURE=0.1

# Shared runtime settings
VISION_SERVICE_READ_TIMEOUT=PT10S
AI_SERVICE_READ_TIMEOUT=PT60S
LOG_LEVEL=INFO
USER_CONTEXT_CACHE_TTL=PT5M
ANALYSIS_JOB_CACHE_TTL=PT15M
ANALYSIS_JOB_KEY_PREFIX=badhabinot:monitoring:analysis-job:

# Frontend local development
VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Vision service — face data & session log storage paths (inside container)
FACE_DATA_DIR=/app/data/users
SESSION_LOG_DIR=/app/logs/sessions

# Firebase Cloud Messaging (optional — push notifications for Android app)
# Download service account key JSON from Firebase Console > Project Settings > Service Accounts
# Set to absolute path of the JSON file (mounted into backend container as needed)
# Dosyayı şuraya koy: infra/firebase/firebase-service-account.json
# Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni Özel Anahtar Oluştur
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/app/config/firebase-service-account.json
FIREBASE_PROJECT_ID=badhabinot

# Ngrok (optional — phone testing without same WiFi)
# https://dashboard.ngrok.com/auth/your-authtoken
NGROK_AUTHTOKEN=

# Optional JVM flags
BACKEND_JAVA_OPTS=
