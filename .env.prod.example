# ═══════════════════════════════════════════════════════
# Badhabinot — SUNUCU Ortam Değişkenleri Şablonu
# Sunucuda: cp .env.prod.example .env.prod
# Çalıştır: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
# ═══════════════════════════════════════════════════════

# ── Veritabanı ──────────────────────────────────────────
POSTGRES_USER=badhabinot
# Sunucu için çok güçlü şifre (32+ karakter)
POSTGRES_PASSWORD=SUNUCU_ICIN_COK_GUCLU_SIFRE
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── Güvenlik ────────────────────────────────────────────
# Sunucuda üret: openssl rand -hex 32
SECURITY_JWT_SECRET=SUNUCU_JWT_SECRET_32_KARAKTER
INTERNAL_API_KEY=SUNUCU_INTERNAL_API_KEY_24_KARAKTER
SECURITY_JWT_ACCESS_TOKEN_TTL=PT15M
SECURITY_JWT_REFRESH_TOKEN_TTL=P30D

# ── Genel erişim (Caddy otomatik HTTPS — Azure ücretsiz FQDN) ─────
# Azure Portal → Public IP → DNS name label ver → aşağıdaki adres oluşur.
PUBLIC_DOMAIN=badhabinot.BOLGE.cloudapp.azure.com
TLS_EMAIL=admin@badhabinot.com

# CORS: *.cloudapp.azure.com OTOMATİK izinli (kod içi). Yalnızca ÖZEL domain
# kullanıyorsan buraya virgülle ekle (yoksa boş bırak).
# Örn: APP_CORS_ALLOWED_ORIGINS=https://app.benimdomain.com,https://benimdomain.com
APP_CORS_ALLOWED_ORIGINS=

# ── Yapay Zeka ───────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_NAME=badhabinot:latest
OLLAMA_BASE_MODEL_NAME=qwen2.5:7b
# Fine-tune edilmiş koç modeli ai-service'in varsayılanı (GGUF sunucuda bulunmalı).
AI_OLLAMA_MODEL_NAME=badhabinot-coach:latest

# Sunucuda OpenAI API kullanmak istersen:
# AI_PROVIDER=openai-compatible
# AI_API_KEY=sk-...
# AI_API_BASE_URL=https://api.openai.com/v1
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL_NAME=gpt-4.1-mini
AI_TIMEOUT_SECONDS=60
AI_READINESS_TIMEOUT_SECONDS=10
AI_MAX_RETRIES=2
AI_TEMPERATURE=0.1

# ── Servis URL'leri (Docker içi — değiştirme) ───────────
AUTH_SERVICE_URL=http://backend:8080
USER_SERVICE_URL=http://backend:8080
MONITORING_SERVICE_URL=http://backend:8080
VISION_SERVICE_URL=http://vision-service:8091
AI_SERVICE_URL=http://ai-service:8092
VISION_SERVICE_READ_TIMEOUT=PT10S
AI_SERVICE_READ_TIMEOUT=PT60S

# ── Veri Dizinleri (Docker volume) ───────────────────────
FACE_DATA_DIR=/app/data/users
SESSION_LOG_DIR=/app/logs/sessions

# ── Cache TTL ────────────────────────────────────────────
USER_CONTEXT_CACHE_TTL=PT5M
ANALYSIS_JOB_CACHE_TTL=PT15M
ANALYSIS_JOB_KEY_PREFIX=badhabinot:monitoring:analysis-job:

# ── Loglama ──────────────────────────────────────────────
LOG_LEVEL=WARN

# ── E-posta (şifre sıfırlama — sunucuda zorunlu) ─────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=admin@badhabinot.com
MAIL_PASSWORD=GMAIL_APP_PASSWORD
# Şifre sıfırlama linki — PUBLIC_DOMAIN ile aynı olmalı
PASSWORD_RESET_URL_TEMPLATE=https://badhabinot.BOLGE.cloudapp.azure.com/reset-password?token={token}

# ── Firebase (Android push bildirimleri) ─────────────────
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/app/config/firebase-service-account.json
# google-services.json → frontend/android/app/google-services.json
# Service account JSON → VM'de ./config/firebase-service-account.json (backend'e mount edilir)

# ── Port Ayarları ────────────────────────────────────────
BACKEND_PORT=8080
VISION_SERVICE_PORT=8091
AI_SERVICE_PORT=8092
FRONTEND_PORT=3000
OLLAMA_PORT=11434

# ── Frontend build ───────────────────────────────────────
VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8080

# ── Bellek (8 GB VM için backend JVM heap sınırı) ────────
# 8 GB RAM'de ollama+vision+backend birlikte sığsın diye heap'i sınırla.
BACKEND_JAVA_OPTS=-Xms256m -Xmx640m

# ── GHCR (GitHub Actions CD — VM önceden derlenmiş imajları çeker) ──
# docker-compose.ghcr.yml bu değerleri kullanır. OWNER = GitHub kullanıcı adı.
GHCR_OWNER=seboii
IMAGE_TAG=latest
